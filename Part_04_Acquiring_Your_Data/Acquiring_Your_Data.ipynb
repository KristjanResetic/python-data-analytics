    "# example 1\n",
    "# prebei datoteko, nastavi oreintacijo prilagojeno kako je v datoteki napisano. v tem priemru je najboljše v columns, edina kaviat je tukaj ker v columnsu vidi dva keya description in data\n",
    "oceans = pd.read_json(data_folder_path / \"ocenas.json\", orient=\"columns\")\n",
    "# izbrišem stolpce s komado .drop\n",
    "# se znebim prevga keya\n",
    "oceans = oceans.drop(columns=\"description\")\n",
    "# se znebim notranjih keyov od prvega keya\n",
    "oceans = oceans.drop([\"title\", \"units\", \"base_period\", \"missing\"])\n",
    "# poimenujem prvi stolpec\n",
    "oceans.index.name = \"year\"\n",
    "# preimenujem data\n",
    "oceans = oceans.rename(columns={\"data\": \"temp_anomaly_celsius\"})\n",
    "# spremenim format časa\n",
    "oceans.index = pd.to_datetime(oceans.index).year\n",
    "oceans.head()"
   ]
