    "import csv\n",
    "import datetime\n",
    "\n",
    "# odprem file po poti\n",
    "file_path = data_folder_path / \"iperf.txt\"\n",
    "# začasna datoteka iz katere bom lahko bral v pandas\n",
    "temp_file_path = data_folder_path / \"iperf_temp.txt\"\n",
    "\n",
    "# odpri datoteko kot f\n",
    "with file_path.open(\"r\") as f:\n",
    "    # preberi vse vrstice\n",
    "    raw_data = f.readlines()\n",
    "    # odstrani odvečne zanke, bresledke...\n",
    "    raw_data = [line.strip() for line in raw_data]\n",
    "\n",
    "# poglej na datetime spletni strani formate kako sprogramirat izpis datuma in uro\n",
    "# na koncu povem da je časovni pas utc\n",
    "# da izvem kdaj se je začelo beležit\n",
    "start_time = datetime.datetime.strptime(raw_data[0], \"%a %b %d %H:%M:%S CEST %Y\").replace(tzinfo=datetime.timezone.utc)\n",
    "\n",
    "print(start_time, type(start_time))\n",
    "\n",
    "rows = []\n",
    "# zanima me šele od 4 vrstice naprej, prej so trenutno nepomenbne info\n",
    "for line in raw_data[4:]:\n",
    "    # dobim list listov\n",
    "    line_splitted = line.split()\n",
    "    # najdem da so na 3 mestu, ločim s piko in vzamem samo prvi element\n",
    "    add_seconds = int(line_splitted[2].split(\".\")[0])\n",
    "    # na un začetni čas dodam sekunde iz meritev, da vidim kdaj je bilo izvedeno\n",
    "    timestamp = start_time + datetime.timedelta(seconds=add_seconds)\n",
    "    # vzamem 4 mesto da dobim byte in pretvorim v int\n",
    "    transfer_mbytesec = int(line_splitted[4])\n",
    "    # vzamem 6 mesto da dobim byte in pretvorim v float\n",
    "    bandwidth_gbitsec = float(line_splitted[6])\n",
    "    retr = int(line_splitted[8])\n",
    "    cwnd_kbytes = int(line_splitted[9])\n",
    "    # v row appendam vse te elemente in dobim lepšo obliko, appendam kot tupple\n",
    "    rows.append((timestamp, transfer_mbytesec, bandwidth_gbitsec, retr, cwnd_kbytes))\n",
    "    # zdaj bi lahko že dal v pandas\n",
    "\n",
    "# definiram glavo tabele\n",
    "headers = [\"timestamp\", \"transfer_mbytesec\", \"bandwidth_gbitsec\", \"retr\", \"cwnd_kbytes\"]\n",
    "\n",
    "# definiram za pisanje v csv\n",
    "with temp_file_path.open(\"w\", newline=\"\") as f:\n",
    "    writer = csv.writer(f)\n",
    "    writer.writerow(headers)\n",
    "    writer.writerows(rows)\n",
    "\n",
    "# nastavim timestamo kot prvo vrstico in čase kot indekse\n",
    "data = pd.read_csv(temp_file_path, parse_dates=[\"timestamp\"], index_col=[\"timestamp\"])\n",
    "data.head(10)\n",
    "\n",
    "\n",
    "# remove the file\n",
    "\n",
    "# temp_file_path.unlink()"
   ]
