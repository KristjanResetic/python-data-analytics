    "# Example 2: Scraping and Visualizing IMDB Ratings\n",
    "\n",
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "\n",
    "url = \"http://www.imdb.com/title/tt0944947/episodes\"\n",
    "\n",
    "episodes = []\n",
    "ratings = []\n",
    "\n",
    "# Go over seasons 1 to 8, spreminja se url ko se premikam čez sezone vidim da se query vrednost spremnija\n",
    "for season in range(1, 9):\n",
    "    # ima osnovno zaščito zato v headerju spremenim user-agenta. pogooglaš what is my user agnet in si to daš kot user-agent\n",
    "    r = requests.get(url, params={\"season\": season}, headers={\"user-agent\": \"Mozilla/5.0\"})\n",
    "    soup = BeautifulSoup(r.text, \"html.parser\")\n",
    "    # poiščem vse te vrednosti oz si jih shranim\n",
    "    listing = soup.find_all(\"div\", class_=\"kBjDMi\")\n",
    "    print(f\"Got data for season {season} with {len(listing)} episodes\")\n",
    "    for epnr, div in enumerate(listing):\n",
    "        # da napišem vsako episodo v sezoni\n",
    "        episode = f\"{season}.{epnr + 1}\"\n",
    "        # ocena epsiode\n",
    "        rating_el = div.find(class_=\"ipc-rating-star--rating\")  # class tag se lahko spremni in potem ne dela več!!!\n",
    "        rating = float(rating_el.get_text(strip=True))\n",
    "        episodes.append(episode)\n",
    "        ratings.append(rating)\n",
    "\n",
    "print(f\"First 10 episodes: {episodes[:10]}\")"
   ]
  },
