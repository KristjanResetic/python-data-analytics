    "# example 4\n",
    "with (data_folder_path / \"transactions.json\").open(\"rt\") as f:\n",
    "    data = json.load(f)\n",
    "\n",
    "# json v pythonu, ga noramliziraj preberi iz data txs, key out, kar je v outu in katere sem definiral iz meta podatkov, podatkov iz gornjega nivoja. dela ko imamo list dictionaryev\n",
    "trans = pd.json_normalize(data[\"txs\"], record_path=[\"out\"], meta=[\"time\", \"relayed_by\", \"vout_sz\", \"hash\"])\n",
    "trans.head()"
