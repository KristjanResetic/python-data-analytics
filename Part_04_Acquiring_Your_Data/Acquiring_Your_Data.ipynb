    "# example 3\n",
    "# v spremenljivko shranim oz preberem datoteko, ki ji povem pot z orientecijo records, ker so podatki shranjeni na zunaj v json kot list, definiram tipe\n",
    "cities = pd.read_json(data_folder_path / \"cities.json\", orient=\"records\", dtype={\"nametype\": \"category\", \"recclass\": \"category\", \"fall\": \"category\"})\n",
    "# ker je gnezedno dictionary nam vrne v tabelo sam dictionary kar ni najbolje za operirati.\n",
    "# iz pandasa lahko pokličem funkcijo, ki lahko to direkt razbije. iz geolokacije si coordinate shranimo kot list z prvim elementom kot x in drugim elementom kot y\n",
    "coordinates = pd.json_normalize(cities[\"geolocation\"].to_list())[\"coordinates\"]\n",
    "# .str lahko zaženem kot indeksiranje lista, tako lahko shranim vsak element v listu pod svojo os koordinate\n",
    "cities[\"coordinates_x\"] = coordinates.str[0]\n",
    "cities[\"coordinates_y\"] = coordinates.str[1]\n",
    "# nastavimo za index stolpec name\n",
    "cities = cities.set_index(\"name\")\n",
    "# z drop zbrišemo zadnji dva stolpca (vrednosti samo pri nekaterih podatkih mest) in geolokacijo\n",
    "cities = cities.drop(columns=[\"geolocation\", \":@computed_region_cbhk_fwbd\", \":@computed_region_nnqa_25f4\", \"id\"])\n",
    "# kot slicing vektorska operacija z .str in število indeksov. shranim kot type as npr float, NaN se obnaša kot float zato ne moremo dat int\n",
    "# cities[\"year\"] = cities[\"year\"] na year na mestu priredim vrednost\n",
    "cities[\"year\"] = cities[\"year\"].astype(str).str[:4].astype(float)\n",
    "cities.head(5)"
   ]
  },
