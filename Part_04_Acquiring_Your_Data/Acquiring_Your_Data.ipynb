   "source": [
    "data = pd.read_csv(\n",
    "    # odpremo folder csv\n",
    "    data_folder_path / \"mpls_stops.csv\",\n",
    "    # damo header oz imena headerjem\n",
    "    names=new_column_names,\n",
    "    # spustim prve dve vrstice, ki so itak enake samo neurejne names\n",
    "    skiprows=2,\n",
    "    # po kateremu programsekmu jeziku naj naredi c in pyarrow sta najhitrejša, python engine lahko vse uporabiš cca 50 parametrov, c je omejen s količino je pa hitrejši, pyarrow nima veliko podpore, najhitrejši?\n",
    "    engine=\"c\",\n",
    "    # pretvori elemente, ki so True v YES\n",
    "    true_values=[\"YES\"],\n",
    "    # pretvori elemente, ki so Flase v NO\n",
    "    false_values=[\"NO\"],\n",
    "    # definiramo kater stolpec naj postane index\n",
    "    index_col=\"case_number_id\",\n",
    "    # poenotimo datume in jih damo na nam razumen format\n",
    "    parse_dates=[\"date\"],\n",
    "    date_format=\"%Y-%m-%d %H:%M:%S\",\n",
    "    # da bo pandas razumel kaj so manjkujoče vrednosti in spremni v NaN. po defaultu da iz csvja kot ozanko Unknow\n",
    "    na_values=[\"Unknown\"],\n",
    "    # da definiramo kako naj pretvori tip podatkov v stolpcu. lahko damo dictionary v kaj naj kaj spremeni. Pandas poskuša sam v naprej definirat tako mu fiknso povemo katere zelimo imet\n",
    "    dtype={\n",
    "        \"mdc\": \"category\",\n",
    "        \"problem\": \"category\",\n",
    "        \"pre_race\": \"category\",\n",
    "        \"race\": \"category\",\n",
    "        \"gender\": \"category\",\n",
    "        \"police_precinct\": \"int8\",\n",
    "        \"neighborhood\": \"category\",\n",
    "    },\n",
    ")\n",
    "# pretvori indekse v tipe int ( tu so bili prej float)\n",
    "data.index = data.index.astype(\"int\")\n",
    "data.head()"
   ]
  },
