    "# izognimo se da delimitre/separtor znak ki bi ga lahko uporablimo v datasetu.\n",
    "# lahko za ločevanje damo drugi znak npr ^,  ~^~0100~^~Butter, salted~^~\n",
    "# example 2: Encoding: `iso-8859-1`, separator: `^`\n",
    "# nrows samo koliko prvih n vrstic naj izpiše\n",
    "# quotechar je navednica za podatke, ki želimo da so skupaj kot ena stvar\n",
    "data = pd.read_csv(data_folder_path / \"FOOD_DES.txt\", sep=\"^\", encoding=\"iso-8859-1\", header=None, nrows=5, quotechar=\"~\")\n",
    "data.head()"
   ]
